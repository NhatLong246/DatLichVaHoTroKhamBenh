@model HeThongDatLichVaKhamBenh.Models.ViewModels.BacSiDashboardViewModel
@{
    Layout = null;
    ViewData["Title"] = "Trang chủ bác sĩ";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="role-page web-dashboard doctor-theme">
    <aside class="role-sidebar">
        <div class="role-brand">
            <div class="role-logo">+</div>
            <div>
                <strong>HealthCare</strong>
                <span>Bác sĩ</span>
            </div>
        </div>
        <nav>
            <a class="active" asp-controller="Dashboard" asp-action="BacSi">Tổng quan</a>
            <a asp-controller="KhamBenh" asp-action="Index">Khám bệnh</a>
            <a asp-controller="LichLamViec" asp-action="Index">Lịch làm việc</a>
            <a asp-controller="CaiDat" asp-action="BacSi">Cài đặt</a>
        </nav>
        <form asp-controller="Account" asp-action="Logout" method="post" class="logout-form" data-confirm-message="Bạn có chắc chắn muốn đăng xuất không?">
            @Html.AntiForgeryToken()
            <button type="submit">Đăng xuất</button>
        </form>
    </aside>

    <main class="role-main">
        <header class="role-header">
            <div>
                <span class="eyebrow">Lịch khám hôm nay</span>
                <h1>Xin chào, @Model.HoTenBacSi</h1>
                <p>Quản lý danh sách bệnh nhân, trạng thái tiếp nhận và lịch làm việc.</p>
            </div>
            <time>@Model.NgayHienTai.ToString("dd/MM/yyyy")</time>
        </header>

        <section class="metric-grid doctor-metrics" aria-label="Số liệu khám bệnh">
            <article class="metric-card">
                <span>Đang chờ khám</span>
                <strong>@Model.DangChoKham.ToString("00")</strong>
                <small>@Model.GhiChuHangCho</small>
            </article>
            <article class="metric-card">
                <span>Đã tiếp nhận</span>
                <strong>@Model.DaTiepNhan.ToString("00")</strong>
                <small>Gồm bệnh nhân đang khám và đã khám</small>
            </article>
            <article class="metric-card">
                <span>Ca làm việc</span>
                <strong>@Model.CaLamViec</strong>
                <small>@Model.PhongKham</small>
            </article>
        </section>

        <section class="search-panel">
            <label for="patientSearch">Tìm kiếm bệnh nhân</label>
            <input id="patientSearch" type="search" placeholder="Nhập tên hoặc số điện thoại" />
        </section>

        <section class="table-section">
            <h2>Danh sách bệnh nhân hôm nay</h2>
            <div class="data-table-wrap">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Tên bệnh nhân</th>
                            <th>Điện thoại</th>
                            <th>Giờ khám</th>
                            <th>Ca khám</th>
                            <th>Phòng khám</th>
                            <th>Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody id="doctorDashboardPatients">
                        @if (Model.BenhNhanHomNay.Count == 0)
                        {
                            <tr>
                                <td colspan="6" class="muted-note">Hôm nay chưa có bệnh nhân trong lịch khám.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model.BenhNhanHomNay)
                            {
                                var statusClass = item.TrangThai == "Đang khám"
                                    ? "info"
                                    : item.TrangThai == "Đã khám"
                                        ? "success"
                                        : "waiting";

                                <tr data-patient="@($"{item.TenBenhNhan} {item.DienThoai}".ToLowerInvariant())">
                                    <td>
                                        <a asp-controller="KhamBenh" asp-action="Index" asp-route-maDangKy="@item.MaDangKy" class="table-link">@item.TenBenhNhan</a>
                                    </td>
                                    <td>@item.DienThoai</td>
                                    <td>@item.GioKhamText</td>
                                    <td>@item.CaKham</td>
                                    <td>@item.TenPhongKham</td>
                                    <td><span class="status @statusClass">@item.TrangThai</span></td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </section>
    </main>
    <script src="~/js/dashboard.js" asp-append-version="true"></script>
    <script>
        (function () {
            const search = document.getElementById("patientSearch");
            const rows = document.querySelectorAll("#doctorDashboardPatients tr[data-patient]");
            search?.addEventListener("input", function () {
                const keyword = search.value.trim().toLowerCase();
                rows.forEach((row) => {
                    row.hidden = keyword.length > 0 && !row.dataset.patient.includes(keyword);
                });
            });
        })();
    </script>
</body>
</html>
