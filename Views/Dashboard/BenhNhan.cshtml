@{
    Layout = null;
    ViewData["Title"] = "Trang chủ bệnh nhân";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="role-page web-dashboard patient-theme">
    <aside class="role-sidebar">
        <div class="role-brand">
            <div class="role-logo">+</div>
            <div>
                <strong>HealthCare</strong>
                <span>Bệnh nhân</span>
            </div>
        </div>
        <nav>
            <a class="active" asp-controller="Dashboard" asp-action="BenhNhan">Tổng quan</a>
            <a asp-controller="LichKham" asp-action="DatLich">Đặt lịch khám</a>
            <a href="#">Lịch hẹn</a>
            <a href="#">Hồ sơ bệnh án</a>
            <a href="#">Hóa đơn</a>
            <a href="#">Đổi mật khẩu</a>
        </nav>
        <form asp-controller="Account" asp-action="Logout" method="post" class="logout-form" data-confirm-message="Bạn có chắc chắn muốn đăng xuất không?">
            @Html.AntiForgeryToken()
            <button type="submit">Đăng xuất</button>
        </form>
    </aside>

    <main class="role-main">
        <header class="role-header">
            <div>
                <span class="eyebrow">Hồ sơ cá nhân</span>
                <h1>Xin chào, @ViewBag.HoTen</h1>
                <p>Theo dõi lịch hẹn, hồ sơ bệnh án và hóa đơn khám bệnh của bạn.</p>
            </div>
            <div class="quick-status">Lịch hẹn sắp tới</div>
        </header>

        <section class="metric-grid patient-metrics" aria-label="Thông tin nhanh">
            <article class="metric-card">
                <span>Lịch hẹn</span>
                <strong>01</strong>
                <small>Đang chờ khám</small>
            </article>
            <article class="metric-card">
                <span>Hồ sơ bệnh án</span>
                <strong>04</strong>
                <small>Lần khám đã lưu</small>
            </article>
            <article class="metric-card">
                <span>Hóa đơn</span>
                <strong>02</strong>
                <small>Đã thanh toán</small>
            </article>
        </section>

        <section class="patient-grid">
            <article class="appointment-panel">
                <div class="panel-heading">Lịch hẹn sắp tới</div>
                <dl>
                    <dt>Bác sĩ</dt>
                    <dd>Hoàng Văn E</dd>
                    <dt>Chuyên khoa</dt>
                    <dd>Ngoại khoa</dd>
                    <dt>Thời gian</dt>
                    <dd>21/11/2025 - Chiều</dd>
                    <dt>Phòng khám</dt>
                    <dd>Phòng Ngoại khoa 1</dd>
                </dl>
            </article>

            <article class="health-summary">
                <span>Trạng thái</span>
                <strong>Chờ khám</strong>
                <p>Vui lòng đến trước giờ hẹn 15 phút để xác nhận thông tin tại quầy tiếp nhận.</p>
            </article>
        </section>

        <section class="action-row">
            <a asp-controller="LichKham" asp-action="DatLich">Đặt lịch khám mới</a>
            <a href="#">Quản lý lịch hẹn</a>
            <a href="#">Hồ sơ bệnh án</a>
        </section>
    </main>
    <script src="~/js/dashboard.js" asp-append-version="true"></script>
</body>
</html>
