@model HeThongDatLichVaKhamBenh.Models.ViewModels.CaiDatViewModel
@{
    Layout = null;
    ViewData["Title"] = "Cài đặt";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="role-page web-dashboard patient-theme">
    <aside class="role-sidebar">
        <div class="role-brand">
            <div class="role-logo">+</div>
            <div>
                <strong>HealthCare</strong>
                <span>Bệnh nhân</span>
            </div>
        </div>
        <nav>
            <a asp-controller="Dashboard" asp-action="BenhNhan">Tổng quan</a>
            <a asp-controller="LichKham" asp-action="DatLich">Đặt lịch khám</a>
            <a asp-controller="LichKham" asp-action="QuanLy">Lịch hẹn</a>
            <a asp-controller="HoSoBenhAn" asp-action="Index">Hồ sơ bệnh án</a>
            <a asp-controller="HoaDon" asp-action="Index">Hóa đơn</a>
            <a class="active" asp-controller="CaiDat" asp-action="Index">Cài đặt</a>
        </nav>
        <form asp-controller="Account" asp-action="Logout" method="post" class="logout-form" data-confirm-message="Bạn có chắc chắn muốn đăng xuất không?">
            @Html.AntiForgeryToken()
            <button type="submit">Đăng xuất</button>
        </form>
    </aside>

    <main class="role-main">
        <header class="role-header">
            <div>
                <span class="eyebrow">Thông tin cá nhân và tài khoản</span>
                <h1>Cài đặt</h1>
                <p>Quản lý thông tin liên hệ, xem thông tin tài khoản và thay đổi mật khẩu đăng nhập.</p>
            </div>
            <div class="quick-status">@Model.HoTen</div>
        </header>

        @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
        {
            <div class="booking-alert booking-alert--success">@Model.SuccessMessage</div>
        }
        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="booking-alert booking-alert--danger">@Model.ErrorMessage</div>
        }

        <div class="container-fluid px-0 mt-4">
            <div class="row justify-content-center">
                <div class="col-12 col-xl-10 col-xxl-9">
                    
                    <!-- Thông tin cá nhân -->
                    <form asp-controller="CaiDat" asp-action="CapNhatThongTin" method="post" class="card shadow-sm border-0 mb-4" style="border-radius: 1rem;">
                        @Html.AntiForgeryToken()
                        <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                            <h5 class="d-flex align-items-center mb-0 fw-bold text-dark">
                                <span class="bg-primary bg-opacity-10 text-primary p-2 rounded-circle me-3">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                                </span>
                                Thông tin cá nhân
                            </h5>
                        </div>
                        <div class="card-body p-4">
                            <div class="row g-4">
                                <div class="col-md-6">
                                    <div class="form-floating">
                                        <input type="text" class="form-control bg-light border-0 fw-semibold text-secondary" id="maBenhNhan" value="@Model.MaBenhNhan" readonly>
                                        <label for="maBenhNhan">Mã bệnh nhân</label>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-floating">
                                        <input type="text" class="form-control bg-light border-0 fw-semibold text-secondary" id="hoTen" value="@Model.HoTen" readonly>
                                        <label for="hoTen">Họ tên</label>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-floating">
                                        <input type="text" class="form-control bg-light border-0 fw-semibold text-secondary" id="ngaySinh" value="@(Model.NgaySinh?.ToString("dd/MM/yyyy") ?? "Chưa cập nhật")" readonly>
                                        <label for="ngaySinh">Ngày sinh</label>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-floating">
                                        <input type="text" class="form-control bg-light border-0 fw-semibold text-secondary" id="gioiTinh" value="@Model.GioiTinh" readonly>
                                        <label for="gioiTinh">Giới tính</label>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-floating">
                                        <input asp-for="DienThoai" class="form-control fw-semibold" placeholder="Nhập số điện thoại" inputmode="numeric" maxlength="10">
                                        <label asp-for="DienThoai">Số điện thoại</label>
                                        <span asp-validation-for="DienThoai" class="text-danger small mt-1 d-block"></span>
                                    </div>
                                </div>
                                <div class="col-md-12">
                                    <div class="form-floating">
                                        <textarea asp-for="DiaChi" class="form-control fw-semibold" placeholder="Nhập địa chỉ" style="height: 100px" maxlength="200"></textarea>
                                        <label asp-for="DiaChi">Địa chỉ liên hệ</label>
                                        <span asp-validation-for="DiaChi" class="text-danger small mt-1 d-block"></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-white border-top-0 pb-4 px-4 text-end">
                            <button type="submit" class="btn btn-primary px-4 py-2 fw-semibold rounded-pill shadow-sm" style="transition: all 0.2s;">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg>
                                Lưu thay đổi
                            </button>
                        </div>
                    </form>

                    <!-- Thông tin tài khoản -->
                    <div class="card shadow-sm border-0 mb-4" style="border-radius: 1rem;">
                        <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                            <h5 class="d-flex align-items-center mb-0 fw-bold text-dark">
                                <span class="bg-info bg-opacity-10 text-info p-2 rounded-circle me-3">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                                </span>
                                Thông tin tài khoản
                            </h5>
                        </div>
                        <div class="card-body p-4">
                            <div class="row g-4">
                                <div class="col-md-6">
                                    <div class="form-floating">
                                        <input type="text" class="form-control bg-light border-0 fw-semibold text-secondary" id="maNguoiDung" value="@Model.MaNguoiDung" readonly>
                                        <label for="maNguoiDung">Mã người dùng</label>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-floating">
                                        <input type="text" class="form-control bg-light border-0 fw-semibold text-secondary" id="tenDangNhap" value="@Model.TenDangNhap" readonly>
                                        <label for="tenDangNhap">Tên đăng nhập</label>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-floating">
                                        <input type="text" class="form-control bg-light border-0 fw-semibold text-secondary" id="vaiTro" value="@Model.VaiTro" readonly>
                                        <label for="vaiTro">Vai trò</label>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-floating">
                                        <input type="text" class="form-control bg-light border-0 fw-semibold text-secondary" id="trangThaiTaiKhoan" value="@Model.TrangThaiTaiKhoan" readonly>
                                        <label for="trangThaiTaiKhoan">Trạng thái</label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Đổi mật khẩu -->
                    <form asp-controller="CaiDat" asp-action="DoiMatKhau" method="post" class="card shadow-sm border-0 mb-4 confirm-form" data-confirm-title="Xác nhận đổi mật khẩu" data-confirm-ok="Đổi mật khẩu" data-confirm-message="Bạn có chắc chắn muốn đổi mật khẩu đăng nhập không?" style="border-radius: 1rem;">
                        @Html.AntiForgeryToken()
                        <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                            <h5 class="d-flex align-items-center mb-0 fw-bold text-dark">
                                <span class="bg-warning bg-opacity-10 text-warning p-2 rounded-circle me-3">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                                </span>
                                Bảo mật & Đổi mật khẩu
                            </h5>
                        </div>
                        <div class="card-body p-4">
                            <div class="row g-4">
                                <div class="col-md-12">
                                    <div class="form-floating position-relative">
                                        <input id="MatKhauHienTai" name="MatKhauHienTai" type="password" class="form-control fw-semibold" placeholder="Mật khẩu hiện tại" style="padding-right: 45px;">
                                        <label for="MatKhauHienTai">Mật khẩu hiện tại</label>
                                        <button type="button" class="btn position-absolute end-0 top-50 translate-middle-y border-0 text-muted p-2 toggle-password" tabindex="-1">
                                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="eye-icon"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                                        </button>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-floating position-relative">
                                        <input id="MatKhauMoi" name="MatKhauMoi" type="password" class="form-control fw-semibold" placeholder="Mật khẩu mới" style="padding-right: 45px;">
                                        <label for="MatKhauMoi">Mật khẩu mới</label>
                                        <button type="button" class="btn position-absolute end-0 top-50 translate-middle-y border-0 text-muted p-2 toggle-password" tabindex="-1">
                                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="eye-icon"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                                        </button>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-floating position-relative">
                                        <input id="XacNhanMatKhauMoi" name="XacNhanMatKhauMoi" type="password" class="form-control fw-semibold" placeholder="Xác nhận mật khẩu mới" style="padding-right: 45px;">
                                        <label for="XacNhanMatKhauMoi">Xác nhận mật khẩu mới</label>
                                        <button type="button" class="btn position-absolute end-0 top-50 translate-middle-y border-0 text-muted p-2 toggle-password" tabindex="-1">
                                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="eye-icon"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-white border-top-0 pb-4 px-4 text-end">
                            <button type="submit" class="btn btn-warning px-4 py-2 fw-semibold rounded-pill shadow-sm text-dark" style="transition: all 0.2s;">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-2"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"></path></svg> 
                                Đổi mật khẩu
                            </button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </main>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/js/dashboard.js" asp-append-version="true"></script>
    <script>
        document.querySelectorAll('.toggle-password').forEach(button => {
            button.addEventListener('click', function() {
                const input = this.previousElementSibling;
                const eyeIcon = this.querySelector('.eye-icon');
                if (input.type === 'password') {
                    input.type = 'text';
                    eyeIcon.innerHTML = '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line>';
                } else {
                    input.type = 'password';
                    eyeIcon.innerHTML = '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle>';
                }
            });
        });
    </script>
</body>
</html>
