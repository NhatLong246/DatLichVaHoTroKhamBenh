@model HeThongDatLichVaKhamBenh.Models.ViewModels.QuanLyLichIndexViewModel
@{
    Layout = null;
    ViewData["Title"] = "Quản lý Lịch Làm Việc";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-theme.css" asp-append-version="true" />
</head>
<body class="role-page web-dashboard admin-theme">
    <partial name="_AdminSidebar" />

    <main class="role-main">
        <header class="role-header welcome-banner" style="margin-bottom: 36px; padding: 24px 40px;">
            <div class="welcome-content">
                <span class="eyebrow" style="color: var(--admin-primary); background: rgba(255,255,255,0.8); padding: 4px 12px; border-radius: 99px; display: inline-block; margin-bottom: 12px;">Điều hành</span>
                <h1>Quản lý Lịch Làm Việc</h1>
                <p>Điều chỉnh, phân công và thiết lập lịch làm việc hàng tuần cho các bác sĩ.</p>
            </div>
            <div style="opacity: 0.15; position: absolute; right: -20px; bottom: -40px; pointer-events: none;">
                <svg width="200" height="200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            </div>
        </header>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert" style="border-radius: 12px; margin-bottom: 24px;">
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <section class="admin-grid" style="grid-template-columns: 1fr;">
            <article class="table-section">
                <div style="padding: 24px 28px; border-bottom: 1px solid var(--admin-border); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px;">
                    <h2 style="margin: 0; padding: 0; border: none;">Danh sách Bác sĩ & Lịch làm việc</h2>
                    
                    <form method="get" action="@Url.Action("Index", "QuanLyLich")" style="display: flex; gap: 12px;">
                        <select name="chuyenKhoaId" class="form-select" style="width: auto; border-radius: 8px;" onchange="this.form.submit()">
                            <option value="">Tất cả chuyên khoa</option>
                            @foreach (var ck in Model.DanhSachChuyenKhoa)
                            {
                                if (Model.ChuyenKhoaId == ck.Value)
                                {
                                    <option value="@ck.Value" selected>@ck.Text</option>
                                }
                                else
                                {
                                    <option value="@ck.Value">@ck.Text</option>
                                }
                            }
                        </select>
                        
                        <div class="input-group" style="width: 250px;">
                            <input type="text" name="search" class="form-control" placeholder="Tìm kiếm tên bác sĩ..." value="@Model.Search" style="border-radius: 8px 0 0 8px;" oninput="clearTimeout(this.delay); this.delay = setTimeout(() => this.form.submit(), 500);">
                            <button class="btn btn-primary" type="submit" style="border-radius: 0 8px 8px 0; background-color: var(--admin-primary); border-color: var(--admin-primary);">Tìm</button>
                        </div>
                    </form>
                </div>
                
                <div class="data-table-wrap">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Mã BS</th>
                                <th>Họ tên</th>
                                <th>Chuyên khoa</th>
                                <th>Số ca / Tuần</th>
                                <th>Trạng thái tài khoản</th>
                                <th style="text-align: right;">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.DanhSachBacSi.Any())
                            {
                                foreach (var item in Model.DanhSachBacSi)
                                {
                                    <tr>
                                        <td>
                                            <div style="color: var(--admin-text-main); font-weight: 700;">@item.MaBacSi</div>
                                        </td>
                                        <td>
                                            <div class="user-info">
                                                <div class="avatar">
                                                    @(string.IsNullOrEmpty(item.HoTen) ? "?" : item.HoTen.Substring(0, 1).ToUpper())
                                                </div>
                                                <span style="font-weight: 600;">@item.HoTen</span>
                                            </div>
                                        </td>
                                        <td>@item.ChuyenKhoa</td>
                                        <td>
                                            @if (item.SoCaLamViec == 0)
                                            {
                                                <span class="status danger" style="background: rgba(239, 68, 68, 0.1); color: var(--admin-danger);">0 ca</span>
                                            }
                                            else
                                            {
                                                <span class="status success" style="background: rgba(16, 185, 129, 0.1); color: var(--admin-success); font-weight: 700;">@item.SoCaLamViec ca</span>
                                            }
                                        </td>
                                        <td>
                                            @if (item.TrangThai)
                                            {
                                                <span class="status success" style="background: rgba(16, 185, 129, 0.1); color: var(--admin-success); border-radius: 99px; padding: 4px 10px; font-weight: 700; font-size: 0.75rem; display: inline-block;">Hoạt động</span>
                                            }
                                            else
                                            {
                                                <span class="status danger" style="background: rgba(239, 68, 68, 0.1); color: var(--admin-danger); border-radius: 99px; padding: 4px 10px; font-weight: 700; font-size: 0.75rem; display: inline-block;">Bị khóa</span>
                                            }
                                        </td>
                                        <td style="text-align: right;">
                                            @if(item.TrangThai)
                                            {
                                                <a href="@Url.Action("Manage", "QuanLyLich", new { id = item.MaBacSi })" class="btn btn-sm" style="background: rgba(79, 70, 229, 0.1); color: var(--admin-primary); border: 1px solid rgba(79, 70, 229, 0.2); border-radius: 8px; padding: 6px 16px; font-weight: 600; text-decoration: none;">Thiết lập lịch</a>
                                            }
                                            else
                                            {
                                                <button disabled class="btn btn-sm" style="background: rgba(100, 116, 139, 0.1); color: #64748b; border: 1px solid rgba(100, 116, 139, 0.2); border-radius: 8px; padding: 6px 16px; font-weight: 600; cursor: not-allowed;">Bị khóa</button>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center text-muted" style="padding: 24px; text-align: center;">Không tìm thấy bác sĩ nào phù hợp</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </article>
        </section>
    </main>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/dashboard.js" asp-append-version="true"></script>
</body>
</html>
