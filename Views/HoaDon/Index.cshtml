@model HeThongDatLichVaKhamBenh.Models.ViewModels.HoaDonViewModel
@using System.Text.Json
@{
    Layout = null;
    ViewData["Title"] = "Hóa đơn";
    var invoiceJson = JsonSerializer.Serialize(Model.HoaDons);
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="role-page web-dashboard patient-theme">
    <aside class="role-sidebar">
        <div class="role-brand">
            <div class="role-logo">+</div>
            <div>
                <strong>HealthCare</strong>
                <span>Bệnh nhân</span>
            </div>
        </div>
        <nav>
            <a asp-controller="Dashboard" asp-action="BenhNhan">Tổng quan</a>
            <a asp-controller="LichKham" asp-action="DatLich">Đặt lịch khám</a>
            <a asp-controller="LichKham" asp-action="QuanLy">Lịch hẹn</a>
            <a asp-controller="HoSoBenhAn" asp-action="Index">Hồ sơ bệnh án</a>
            <a class="active" asp-controller="HoaDon" asp-action="Index">Hóa đơn</a>
            <a asp-controller="CaiDat" asp-action="Index">Cài đặt</a>
        </nav>
        <form asp-controller="Account" asp-action="Logout" method="post" class="logout-form" data-confirm-message="Bạn có chắc chắn muốn đăng xuất không?">
            @Html.AntiForgeryToken()
            <button type="submit">Đăng xuất</button>
        </form>
    </aside>

    <main class="role-main">
        <header class="role-header">
            <div>
                <span class="eyebrow">Quản lý tài chính khám chữa bệnh</span>
                <h1>Hóa đơn thanh toán</h1>
                <p>Theo dõi các khoản chi phí khám bệnh, thuốc, trạng thái hóa đơn và xác nhận thanh toán khi cần.</p>
            </div>
            <div class="quick-status">@Model.HoTenBenhNhan</div>
        </header>

        @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
        {
            <div class="booking-alert booking-alert--success">@Model.SuccessMessage</div>
        }
        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="booking-alert booking-alert--danger">@Model.ErrorMessage</div>
        }

        <section class="metric-grid invoice-metrics" aria-label="Tổng quan hóa đơn">
            <article class="metric-card animate-hover border-0 shadow-sm" style="border-radius: 16px;">
                <div class="d-flex align-items-start justify-content-between mb-2">
                    <span class="text-uppercase fw-bold text-muted small">Tổng hóa đơn</span>
                    <div class="rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 42px; height: 42px; background: #e0f2fe; color: #0284c7;">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                    </div>
                </div>
                <strong class="display-5 fw-bolder text-dark mb-1">@Model.TongHoaDon.ToString("00")</strong>
                <small class="text-secondary fw-semibold">Toàn bộ lịch sử</small>
            </article>
            <article class="metric-card animate-hover border-0 shadow-sm" style="border-radius: 16px;">
                <div class="d-flex align-items-start justify-content-between mb-2">
                    <span class="text-uppercase fw-bold text-muted small">Chưa thanh toán</span>
                    <div class="rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 42px; height: 42px; background: #fef08a; color: #a16207;">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                    </div>
                </div>
                <strong class="display-5 fw-bolder text-dark mb-1">@Model.ChuaThanhToan.ToString("00")</strong>
                <small class="text-warning fw-semibold">Cần xử lý</small>
            </article>
            <article class="metric-card animate-hover border-0 shadow-sm" style="border-radius: 16px;">
                <div class="d-flex align-items-start justify-content-between mb-2">
                    <span class="text-uppercase fw-bold text-muted small">Đã thanh toán</span>
                    <div class="rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 42px; height: 42px; background: #dcfce7; color: #16a34a;">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                    </div>
                </div>
                <strong class="display-5 fw-bolder text-dark mb-1">@Model.DaThanhToan.ToString("00")</strong>
                <small class="text-success fw-semibold">Đã hoàn tất</small>
            </article>
            <article class="metric-card animate-hover border-0 shadow-sm" style="border-radius: 16px;">
                <div class="d-flex align-items-start justify-content-between mb-2">
                    <span class="text-uppercase fw-bold text-muted small">Tổng chi phí</span>
                    <div class="rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 42px; height: 42px; background: #f3e8ff; color: #7e22ce;">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
                    </div>
                </div>
                <strong class="display-5 fw-bolder text-dark mb-1">@Model.TongChiPhi.ToString("N0")</strong>
                <small class="text-primary fw-semibold" style="color: #7e22ce !important;">VNĐ</small>
            </article>
        </section>

        @if (Model.HoaDons.Count == 0)
        {
            <article class="empty-state border-0 shadow-sm" style="border-radius: 16px;">
                <div class="mb-3 text-muted">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                </div>
                <h2>Chưa có hóa đơn</h2>
                <p>Hóa đơn sẽ xuất hiện sau khi phòng khám lập chi phí cho lần khám của bạn.</p>
                <a class="booking-button booking-button--primary text-decoration-none d-inline-flex align-items-center justify-content-center mt-3 px-4 py-2" asp-controller="HoSoBenhAn" asp-action="Index">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                    Xem hồ sơ bệnh án
                </a>
            </article>
        }
        else
        {
            <section class="invoice-shell" aria-label="Danh sách và chi tiết hóa đơn">
                <div class="invoice-list-panel shadow-sm border-0 bg-white" style="border-radius: 16px; overflow: hidden;">
                    <div class="panel-heading d-flex align-items-center" style="border-radius: 16px 16px 0 0;"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-2 text-primary"><line x1="8" y1="6" x2="21" y2="6"></line><line x1="8" y1="12" x2="21" y2="12"></line><line x1="8" y1="18" x2="21" y2="18"></line><line x1="3" y1="6" x2="3.01" y2="6"></line><line x1="3" y1="12" x2="3.01" y2="12"></line><line x1="3" y1="18" x2="3.01" y2="18"></line></svg> Danh sách hóa đơn</div>
                    <div class="invoice-list" id="invoiceList"></div>
                </div>

                <div class="invoice-detail-panel shadow-sm border-0 bg-white" style="border-radius: 16px; overflow: hidden;">
                    <div class="invoice-detail__header p-4" style="border-bottom: 1px solid #f1f5f9; background: #f8fafc;">
                        <div>
                            <span id="invoiceCode" class="appointment-code badge bg-light text-secondary border mb-2 px-2 py-1"></span>
                            <h2 id="invoiceTitle" class="h5 fw-bold text-dark mb-1">Chi tiết hóa đơn</h2>
                            <p id="invoiceMeta" class="text-muted mb-0 small fw-semibold"></p>
                        </div>
                        <span id="invoiceStatus" class="status waiting px-3 py-1 rounded-pill fw-bold border"></span>
                    </div>

                    <dl class="invoice-summary-grid">
                        <div>
                            <dt>Tổng tiền</dt>
                            <dd id="invoiceTotal"></dd>
                        </div>
                        <div>
                            <dt>Hình thức thanh toán</dt>
                            <dd id="invoiceMethod"></dd>
                        </div>
                        <div>
                            <dt>Ngày lập</dt>
                            <dd id="invoiceDate"></dd>
                        </div>
                    </dl>

                    <div class="data-table-wrap">
                        <table class="data-table medical-table">
                            <thead>
                                <tr>
                                    <th>Phiếu khám</th>
                                    <th>Thông tin khám</th>
                                    <th>Tiền khám</th>
                                    <th>Tiền thuốc</th>
                                    <th>Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody id="invoiceDetailBody"></tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="4">Tổng cộng</td>
                                    <td id="invoiceDetailTotal"></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>

                    <form asp-controller="HoaDon" asp-action="ThanhToan" method="post" class="invoice-payment-form confirm-form" id="paymentForm" data-confirm-title="Xác nhận thanh toán" data-confirm-ok="Thanh toán" data-confirm-message="Bạn có chắc chắn muốn xác nhận thanh toán hóa đơn này không?">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="maHoaDon" id="paymentInvoiceId" />
                        <label for="paymentMethod">Hình thức thanh toán</label>
                        <div class="payment-controls">
                            <select name="hinhThucThanhToan" id="paymentMethod">
                                <option value="Chuyển khoản">Chuyển khoản</option>
                                <option value="Thẻ">Thẻ</option>
                                <option value="Tiền mặt">Tiền mặt</option>
                                <option value="Bảo hiểm">Bảo hiểm</option>
                            </select>
                            <button type="submit">Thanh toán</button>
                        </div>
                    </form>
                </div>
            </section>
        }
    </main>

    <script>
        window.invoiceData = @Html.Raw(invoiceJson);
    </script>
    <script src="~/js/dashboard.js" asp-append-version="true"></script>
    <script>
        (() => {
            const invoices = window.invoiceData || [];
            if (!invoices.length) {
                return;
            }

            const invoiceList = document.getElementById("invoiceList");
            const invoiceCode = document.getElementById("invoiceCode");
            const invoiceTitle = document.getElementById("invoiceTitle");
            const invoiceMeta = document.getElementById("invoiceMeta");
            const invoiceStatus = document.getElementById("invoiceStatus");
            const invoiceTotal = document.getElementById("invoiceTotal");
            const invoiceMethod = document.getElementById("invoiceMethod");
            const invoiceDate = document.getElementById("invoiceDate");
            const invoiceDetailBody = document.getElementById("invoiceDetailBody");
            const invoiceDetailTotal = document.getElementById("invoiceDetailTotal");
            const paymentForm = document.getElementById("paymentForm");
            const paymentInvoiceId = document.getElementById("paymentInvoiceId");
            const paymentMethod = document.getElementById("paymentMethod");
            const currency = new Intl.NumberFormat("vi-VN", { style: "currency", currency: "VND" });
            let selectedIndex = 0;

            const valueOf = (item, name) => item[name] ?? "";
            const escapeHtml = (value) => String(value ?? "")
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll("\"", "&quot;")
                .replaceAll("'", "&#039;");
            const formatDate = (value) => value ? new Date(`${value}T00:00:00`).toLocaleDateString("vi-VN") : "Chưa cập nhật";
            const formatMoney = (value) => currency.format(Number(value || 0));
            const statusClass = (status) => {
                if (status === "Đã thanh toán") return "success";
                if (status === "Đã hủy") return "danger";
                return "waiting";
            };

            function renderInvoiceList() {
                invoiceList.innerHTML = invoices.map((invoice, index) => `
                    <button type="button" class="invoice-choice${index === selectedIndex ? " is-selected" : ""}" data-invoice-index="${index}">
                        <span>${escapeHtml(valueOf(invoice, "MaHoaDon"))}</span>
                        <strong>${formatMoney(valueOf(invoice, "TongTien"))}</strong>
                        <small>${escapeHtml(formatDate(valueOf(invoice, "NgayLap")))} · ${escapeHtml(valueOf(invoice, "TrangThai"))}</small>
                    </button>
                `).join("");
            }

            function renderInvoiceDetail(invoice) {
                const details = valueOf(invoice, "ChiTietHoaDons") || [];
                const total = Number(valueOf(invoice, "TongTien") || details.reduce((sum, item) => sum + Number(valueOf(item, "ThanhTien") || 0), 0));
                const status = valueOf(invoice, "TrangThai") || "Chưa thanh toán";

                invoiceCode.textContent = valueOf(invoice, "MaHoaDon");
                invoiceTitle.textContent = `Hóa đơn ${valueOf(invoice, "MaHoaDon")}`;
                invoiceMeta.textContent = `Ngày lập: ${formatDate(valueOf(invoice, "NgayLap"))}`;
                invoiceStatus.textContent = status;
                invoiceStatus.className = `status ${statusClass(status)}`;
                invoiceTotal.textContent = formatMoney(total);
                invoiceMethod.textContent = valueOf(invoice, "HinhThucThanhToan") || "Chưa chọn";
                invoiceDate.textContent = formatDate(valueOf(invoice, "NgayLap"));
                invoiceDetailTotal.textContent = formatMoney(total);

                if (!details.length) {
                    invoiceDetailBody.innerHTML = "<tr><td colspan=\"5\">Hóa đơn này chưa có chi tiết.</td></tr>";
                } else {
                    invoiceDetailBody.innerHTML = details.map((detail) => `
                        <tr>
                            <td>${escapeHtml(valueOf(detail, "MaPhieuKham"))}<small>Đơn thuốc: ${escapeHtml(valueOf(detail, "MaDonThuoc"))}</small></td>
                            <td>
                                ${escapeHtml(formatDate(valueOf(detail, "NgayKham")))} - ${escapeHtml(valueOf(detail, "CaKham"))}
                                <small>${escapeHtml(valueOf(detail, "TenBacSi"))} · ${escapeHtml(valueOf(detail, "TenChuyenKhoa"))} · ${escapeHtml(valueOf(detail, "TenPhongKham"))}</small>
                                <small>${escapeHtml(valueOf(detail, "GhiChu"))}</small>
                            </td>
                            <td>${formatMoney(valueOf(detail, "TienKham"))}</td>
                            <td>${formatMoney(valueOf(detail, "TienThuoc"))}</td>
                            <td>${formatMoney(valueOf(detail, "ThanhTien"))}</td>
                        </tr>
                    `).join("");
                }

                paymentInvoiceId.value = valueOf(invoice, "MaHoaDon");
                paymentForm.classList.toggle("is-hidden", status !== "Chưa thanh toán");
                paymentForm.dataset.confirmMessage = `Bạn có chắc chắn muốn xác nhận thanh toán hóa đơn ${valueOf(invoice, "MaHoaDon")} với số tiền ${formatMoney(total)} không?`;

                const method = valueOf(invoice, "HinhThucThanhToan");
                if (["Chuyển khoản", "Thẻ", "Tiền mặt", "Bảo hiểm"].includes(method)) {
                    paymentMethod.value = method;
                } else {
                    paymentMethod.value = "Chuyển khoản";
                }
            }

            function selectInvoice(index) {
                selectedIndex = index;
                renderInvoiceList();
                renderInvoiceDetail(invoices[selectedIndex]);
            }

            invoiceList.addEventListener("click", (event) => {
                const button = event.target.closest("[data-invoice-index]");
                if (!button) {
                    return;
                }

                selectInvoice(Number(button.dataset.invoiceIndex));
            });

            selectInvoice(0);
        })();
    </script>
</body>
</html>
